


@model List<Souq.Models.Product>




<div style="margin:auto" class="container mt-5 mb-5">

    <form asp-action="ProductSearch" asp-controller="Home" method="get">
        <div class="row">
            <input type="submit" class="col-sm-2 btn btn-primary" value="ابحث" />

            <div class="col-sm-10">
                <input type="text" name="xname" id="xname" style="text-align:right" class="form-control" placeholder="البحث" />
            </div>
        </div>
    </form>


</div>






<section id="services" class="services section">

    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>البحث عن المنتجات  </h2>
        <p>Necessitatibus eius consequatur ex aliquid fuga eum quidem sint consectetur velit</p>
    </div><!-- End Section Title -->

    <div class="container isotope-layout">

        <div class="row isotope-container g-4">

            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6 portfolio-item isotope-item" data-aos="fade-up" data-aos-delay="100">
                    <div class="product-card">
                        @* <span class="brand-logo">a</span> *@

                        <a href="@item.Photo"
                           data-gallery="portfolio-gallery"
                           class="glightbox product-image">
                            <img src="/@item.Photo" alt="@item.Name">
                        </a>

                        <div class="product-info">
                            <h4>
                                <a href="/Home/currentProduct/@item.Id">
                                    @item.Name
                                </a>
                            </h4>

                            <span class="price">$@item.Price</span>

                            <a asp-controller="Cart"
                               asp-action="AddToCart"
                               asp-route-productId="@item.Id"
                               class="btn add-cart-btn">
                                <i class="bi bi-plus"></i> Add to Cart
                            </a>
                        </div>
                    </div>
                </div>
            }


            <!-- End Service Item -->


        </div>

    </div>

</section>
