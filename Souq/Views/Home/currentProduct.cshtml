@model Product

<section id="portfolio-details" class="portfolio-details section">
    <div class="container" data-aos="fade-up">

        <div class="row">
            @* --- الجانب الأيسر: عرض الصور (أسلوب أمازون) --- *@
            <div class="col-lg-7">
                <div class="row">
                    @* 1. الصور المصغرة على الجنب (Thumbnails) *@
                    <div class="col-2 thumbnails-container px-1">

                        @* الصورة الأساسية *@
                        <div class="thumb-box active" onmouseover="changeMainImage('@Url.Content("~/" + Model.Photo)', this)">
                            <img src="@Url.Content("~/" + Model.Photo)" class="img-fluid" alt="Main Photo">
                        </div>

                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            foreach (var img in Model.ProductImages)
                            {
                                @* منع تكرار الصورة الأساسية لو مرفوعة مرتين *@
                                if (img.Image != Model.Photo)
                                {
                                    <div class="thumb-box" onmouseover="changeMainImage('@Url.Content("~/" + img.Image)', this)">
                                        <img src="@Url.Content("~/" + img.Image)" class="img-fluid" alt="Product Image">
                                    </div>
                                }
                            }
                        }
                    </div>

                    @* 2. الصورة الكبيرة المعروضة *@
                    <div class="col-10 main-image-container">
                        <div class="img-wrapper shadow-sm border rounded">
                            <img id="mainImage" src="@Url.Content("~/" + Model.Photo)" class="img-fluid main-img-display">
                        </div>
                    </div>
                </div>
            </div>

            @* --- الجانب الأيمن: معلومات المنتج --- *@
            <div class="col-lg-5">
                <div class="portfolio-info" style="direction:rtl">
                    <h2 class="fw-bold">@Model.Name</h2>
                    <div class="price-tag my-3">
                        <span class="h3 text-danger fw-bold">LE @Model.Price.ToString("N2")</span>
                    </div>
                    <p class="description text-muted">@Model.Description</p>
                    <hr />
                    <ul class="list-unstyled p-0">
                        <li class="mb-2"><strong>القسم:</strong> @Model.Cat?.Name</li>
                        <li class="mb-2"><strong>المورد:</strong> @Model.SupplierName</li>
                        <li class="mb-2"><strong>التاريخ:</strong> @Model.EntryData</li>
                    </ul>

                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@Model.Id"
                       class="btn btn-warning w-100 fw-bold py-3 mt-3 shadow-sm amazon-btn">
                        <i class="bi bi-cart-plus-fill"></i> إضافة إلى السلة
                    </a>
                </div>
            </div>
        </div>

    </div>
</section>

@* --- قسم المنتجات المشابهة --- *@
<section id="related-products" class="portfolio-details section mt-5">
    <div class="container" data-aos="fade-up">
        <div class="section-title text-center mb-4">
            <h2 class="fw-bold">منتجات مشابهة</h2>
        </div>

        <div class="swiper init-swiper related-swiper position-relative">
            <script type="application/json" class="swiper-config">
                {
                  "loop": false,
                  "rewind": true,
                  "speed": 600,
                  "autoplay": false,
                  "slidesPerView": "auto",
                  "watchOverflow": true,
                  "simulateTouch": true,
                  "grabCursor": true,
                  "navigation": {
                    "nextEl": ".swiper-button-next",
                    "prevEl": ".swiper-button-prev"
                  },
                  "pagination": {
                    "el": ".swiper-pagination",
                    "type": "bullets",
                    "clickable": true
                  },
                  "breakpoints": {
                    "320": { "slidesPerView": 2, "spaceBetween": 20 },
                    "768": { "slidesPerView": 3, "spaceBetween": 30 },
                    "1200": { "slidesPerView": 4, "spaceBetween": 40 }
                  }
                }
            </script>

            <div class="swiper-wrapper">
                @if (ViewBag.RelatedProducts != null)
                {
                    foreach (var item in (List<Product>)ViewBag.RelatedProducts)
                    {
                        <div class="swiper-slide">
                            <div class="card h-100 shadow-sm border-0">
                                <a asp-action="Details" asp-route-id="@item.Id">
                                    <img src="@Url.Content("~/" + item.Photo)" class="card-img-top"
                                         style="height: 180px; object-fit: contain; padding: 10px;">
                                </a>
                                <div class="card-body text-center">
                                    <h6 class="card-title text-truncate">@item.Name</h6>
                                    <p class="text-primary fw-bold">LE @item.Price</p>
                                    <a asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-cart-plus"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            @* أزرار التنقل *@
            <div class="swiper-button-prev custom-nav"></div>
            <div class="swiper-button-next custom-nav"></div>
            <div class="swiper-pagination mt-4"></div>
        </div>
    </div>
</section>

<style>
    /* تنسيق الصور الجانبية */
    .thumbnails-container {
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-height: 450px;
        overflow-y: auto;
    }

    .thumb-box {
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 2px;
        cursor: pointer;
        transition: 0.2s;
        background: #fff;
    }

        .thumb-box:hover, .thumb-box.active {
            border-color: #e77600;
            box-shadow: 0 0 3px 2px rgba(228, 121, 17, .3);
        }

    .main-image-container .img-wrapper {
        background: #fff;
        padding: 15px;
        min-height: 450px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .main-img-display {
        max-height: 430px;
        object-fit: contain;
    }

    /* زرار أمازون */
    .amazon-btn {
        background-color: #ffd814 !important;
        border-color: #fcd200 !important;
        color: #0f1111 !important;
    }

    /* تنسيق سلايدر المشابهة */
    .related-swiper {
        padding: 40px 20px;
    }

    .custom-nav {
        color: #007bff !important;
        background: rgba(255, 255, 255, 0.9);
        width: 35px !important;
        height: 35px !important;
        border-radius: 50%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        top: 45% !important;
    }

        .custom-nav::after {
            font-size: 14px !important;
            font-weight: bold;
        }

    .swiper-button-disabled {
        opacity: 0;
        pointer-events: none;
    }
</style>

<script>
    function changeMainImage(imgUrl, element) {
        // تغيير الصورة الكبيرة
        document.getElementById('mainImage').src = imgUrl;

        // تحديث البرواز النشط
        const thumbs = document.querySelectorAll('.thumb-box');
        thumbs.forEach(box => box.classList.remove('active'));
        element.classList.add('active');
    }
</script>