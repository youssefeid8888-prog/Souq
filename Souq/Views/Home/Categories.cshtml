@{
    Layout = "~/Views/Shared/_FooterLayout.cshtml";
}

@model List<Souq.Models.Catigory>

<style>
    /* تنسيق قسم الخدمات/الأقسام */
    .services .service-item {
        padding: 40px;
        box-shadow: 0px 0 30px rgba(0, 0, 0, 0.08);
        height: 100%;
        background: #fff;
        border-radius: 15px;
        transition: all 0.3s ease-in-out;
        border: 1px solid #eee;
    }

        .services .service-item:hover {
            transform: translateY(-10px);
            box-shadow: 0px 10px 40px rgba(0, 0, 0, 0.12);
            border-color: #007bff;
        }

        /* تنسيق الأيقونة */
        .services .service-item .icon {
            margin-left: 20px;
            width: 64px;
            height: 64px;
            background: #f0f7ff;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #007bff;
            font-size: 28px;
            transition: 0.3s;
        }

        .services .service-item:hover .icon {
            background: #007bff;
            color: #fff;
        }

        /* تنسيق النصوص */
        .services .service-item .title {
            font-weight: 700;
            margin-bottom: 15px;
            font-size: 20px;
        }

            .services .service-item .title a {
                color: #222;
                transition: 0.3s;
                text-decoration: none;
            }

        .services .service-item .description {
            line-height: 24px;
            font-size: 14px;
            color: #666;
            margin-bottom: 0;
        }

    /* تنسيق زرار المدير */
    .admin-control-btn {
        margin-top: 30px;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 4px 15px rgba(0, 123, 255, 0.3);
    }
</style>

<section id="services" class="services section">

    <div class="container section-title text-center" data-aos="fade-up">
        <h2 class="fw-bold">الأقسام المتاحة</h2>
        <p class="text-muted">اختر القسم الذي تريد تصفح منتجاته واستمتع بتجربة تسوق فريدة</p>
    </div>

    <div class="container">
        <div class="row gy-4 mt-2" style="direction:rtl">

            @foreach (var item in Model)
            {
                <div class="col-xl-4 col-lg-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="service-item d-flex align-items-start">
                        <div class="icon flex-shrink-0">
                            <i class="bi @(string.IsNullOrEmpty(item.Photo) ? "bi-box" : item.Photo)"></i>
                        </div>
                        <div class="ms-3">
                            <h4 class="title">
                                <a href="/home/Products/@item.Id" class="stretched-link">@item.Name</a>
                            </h4>
                            <p class="description">@item.Description</p>
                        </div>
                    </div>
                </div>
            }

        </div>

        @if (ViewBag.isAdmin != null && (bool)ViewBag.isAdmin)
        {
            <div class="text-center mt-5">
                <a href="/Catigories" class="btn btn-primary admin-control-btn">
                    <i class="bi bi-gear-fill"></i> لوحة تحكم الأقسام (للمديرين فقط)
                </a>
            </div>
        }

    </div>

</section>